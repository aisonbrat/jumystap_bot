# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.

BOT_TOKEN=your_telegram_bot_token_here
BOT_PASSWORD=Gorifa10

# Production webhook (Vercel)
WEBHOOK_BASE_URL=https://jumystapbot.vercel.app

# Upstash → your database → REST API tab (HTTPS URL + token)
# Do NOT use the rediss:// TCP URL — it does not work on Vercel serverless.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# Optional
# WEBHOOK_SECRET=your_secret
# PORT=8080
